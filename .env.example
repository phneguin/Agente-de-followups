# ════════════════════════════════════════════════
#  Agente de Follow-up — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
# ════════════════════════════════════════════════

# ── Z-API (WhatsApp) ─────────────────────────────
ZAPI_INSTANCE_ID=SEU_INSTANCE_ID
ZAPI_TOKEN=SEU_TOKEN
ZAPI_CLIENT_TOKEN=CRIE_UM_TOKEN_SEGURO_AQUI

# ── Anthropic (Claude IA) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Alertas WhatsApp ──────────────────────────────
PEDRO_ALERT_PHONE=5531988706010

# ── Notificações por E-mail (Gmail) ─────────────
# Para ativar:
#   1. Ative a verificação em 2 etapas no Google
#   2. myaccount.google.com → Segurança → Senhas de app
#   3. Crie senha de app (16 chars) e use abaixo
SMTP_USER=phpereiradasilva@gmail.com
SMTP_PASS=
NOTIFICATION_EMAIL=phpereiradasilva@gmail.com

# ── Identidade ────────────────────────────────────
SELLER_NAME=Pedro
COMPANY_NAME=Metalsol Serviços de Energia Solar

# ── Horário comercial (Brasília) ──────────────────
BUSINESS_HOUR_START=8
BUSINESS_HOUR_END=18

# ── Scheduler ─────────────────────────────────────
SCHEDULER_INTERVAL_MINUTES=30
MAX_FOLLOWUPS_PER_RUN=30

# ── Servidor ──────────────────────────────────────
PORT=8000
